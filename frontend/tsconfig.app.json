{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@admin-shell/ui/plugin-api": ["packages/admin-shell-ui/src/utils/pluginApi.ts"],
      "@admin-shell/ui/plugin-component-registry": ["packages/admin-shell-ui/src/utils/pluginComponentRegistry.ts"],
      "@admin-shell/ui/plugin-services": ["packages/admin-shell-ui/src/utils/pluginServices.ts"],
      "@admin-shell/ui/event-bus": ["packages/admin-shell-ui/src/utils/eventBus.ts"],
      "@admin-shell/ui/http-client": ["packages/admin-shell-ui/src/http-client/index.ts"],
      "@admin-shell/ui/types": ["packages/admin-shell-ui/src/types/index.ts"],
      "@admin-shell/ui/*": ["packages/admin-shell-ui/src/*"]
    },
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "packages/**/*.vue"
  ]
}
