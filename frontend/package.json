{
  "name": "admin-shell-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "copy:order-plugin": "node scripts/copy-order-plugin.mjs",
    "generate:api-client": "bash scripts/generate-api-client.sh",
    "build": "npm --prefix ../plugins/OrderCreationPlugin/FrontEnd run build:frontend && node scripts/copy-order-plugin.mjs && npm run generate:api-client -- --api-url http://127.0.0.1:5000 && vue-tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.17.0",
    "element-plus": "^2.9.10",
    "pinia": "^3.0.2",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/vue": "^8.0.0",
    "@types/node": "^25.9.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "^10.4.1",
    "eslint-plugin-vue": "^10.9.2",
    "happy-dom": "^20.10.3",
    "jsdom": "^29.1.1",
    "orval": "^7.21.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vue-tsc": "^2.2.8"
  }
}
