{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Serilog": {
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/adminshell-.json",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  },
  "Logs": {
    "Path": "logs/adminshell-.json",
    "MaxScanBytes": 10485760
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1434;Database=AdminShell;User Id=sa;Password=Admin123!;TrustServerCertificate=true;Encrypt=false;"
  }
}
