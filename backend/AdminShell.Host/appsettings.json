{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/adminshell-.json",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1434;Database=AdminShell;User Id=sa;Password=Admin123!;TrustServerCertificate=true;Encrypt=false;"
  },
  "Logs": {
    "Path": "logs/adminshell-.json",
    "MaxScanBytes": 10485760
  },
  "Jwt": {
    "Secret": "a-very-long-secret-key-that-should-be-at-least-32-characters-long",
    "Issuer": "AdminShell",
    "Audience": "AdminShell",
    "ExpiryMinutes": "60"
  },
  "Cors": {
    "Origins": "http://localhost:5173"
  },
  "Plugins": {
    "Directory": "../plugins"
  },
  "AllowedHosts": "*"
}